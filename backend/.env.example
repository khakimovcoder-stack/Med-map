# =====================================================================
#  MED MAP — Backend environment variables
#  Copy this file to `.env` for local dev, or paste these keys into the
#  Railway dashboard "Variables" tab for production.
# =====================================================================

# ----- Django core -----
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
# In dev, "*" is fine. In prod set to your Railway domain (Railway also
# exposes RAILWAY_PUBLIC_DOMAIN, which the app trusts automatically).
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Comma-separated origins for CSRF (https only in prod).
# Railway domain is auto-trusted; add your custom domain here if any.
CSRF_TRUSTED_ORIGINS=

# ----- Database -----
# Local dev uses SQLite when DATABASE_URL is empty.
# On Railway, attach a Postgres plugin and DATABASE_URL is injected automatically.
DATABASE_URL=

# ----- CORS -----
# Frontend origins allowed to call the API.
# Add your Vercel preview/prod URLs here.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Regex auto-allows every *.vercel.app URL (preview deploys).
CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.vercel\.app$
# In dev set to True; in prod keep False and rely on the lists above.
CORS_ALLOW_ALL_ORIGINS=True

# ----- JWT -----
JWT_ACCESS_TOKEN_LIFETIME_SECONDS=86400

# ----- OneID mock -----
ONEID_MOCK_OTP=123456
ONEID_OTP_TTL_SECONDS=300
