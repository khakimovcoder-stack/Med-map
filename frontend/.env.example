# =====================================================================
#  MED MAP — Frontend environment variables
#  Copy to `.env` for local dev. On Vercel, paste these into
#  Project Settings → Environment Variables (do NOT commit real values).
# =====================================================================

# Public API base URL (no trailing slash).
# Local dev:   http://localhost:8000/api/v1
# Production:  https://<your-railway-app>.up.railway.app/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# When true, repositories return in-memory mock data instead of hitting the API.
# Set to "false" once the backend is reachable.
VITE_USE_MOCK=false
